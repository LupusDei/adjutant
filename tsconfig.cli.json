{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist/cli",
    "rootDir": "cli",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["cli/**/*.ts"],
  "//": "Test files (vitest) are not part of the production CLI build.",
  "exclude": ["cli/**/*.test.ts", "cli/tests/**"]
}
